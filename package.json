{
  "name": "hexstacker-party",
  "version": "3.4.0",
  "description": "Browser-based multiplayer hex stacker with phone controllers",
  "main": "server/index.js",
  "scripts": {
    "start": "node scripts/generate-airconsole-html.js && node server/index.js",
    "dev": "node scripts/generate-airconsole-html.js && node --watch server/index.js",
    "test": "node --test tests/*.test.js",
    "test:e2e": "npx playwright test --project=e2e",
    "test:e2e:airconsole": "AC_MOCK=1 npx playwright test --project=e2e-airconsole",
    "ad:capture": "node artwork/ad-clip/capture.js",
    "ad:stitch": "node artwork/ad-clip/stitch.js",
    "ad": "npm run ad:capture && npm run ad:stitch",
    "ad:short": "AD_VARIANT=short npm run ad",
    "ad:clean": "AD_VARIANT=clean npm run ad",
    "ad:prod": "AD_PROD=1 npm run ad",
    "ad:prod:short": "AD_PROD=1 AD_VARIANT=short npm run ad",
    "ad:prod:clean": "AD_PROD=1 AD_VARIANT=clean npm run ad"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
