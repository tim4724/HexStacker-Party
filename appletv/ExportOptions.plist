<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- xcodebuild -exportArchive options used by .github/workflows/release.yml.
     Mirrors the manual signing setup in project.yml: Apple Distribution cert +
     the named App Store provisioning profile. destination=upload pushes the
     build to App Store Connect via the ASC API key (release.yml passes the
     -authenticationKey* args); the TestFlight build is the deliverable, no
     .ipa is written. For a one-off local .ipa, export with
     -exportOptionsPlist <(plutil -replace destination -string export -o - ExportOptions.plist).
     manageAppVersionAndBuildNumber=false keeps xcodebuild from second-guessing
     the version: release builds stamp MARKETING_VERSION (from the git tag) and
     CURRENT_PROJECT_VERSION (run number) explicitly at archive time. -->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>upload</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>teamID</key>
	<string>5ZH48MPAM3</string>
	<key>signingCertificate</key>
	<string>Apple Distribution</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.hexstacker.tv</key>
		<string>HexStacker tvOS App Store</string>
	</dict>
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
</dict>
</plist>
