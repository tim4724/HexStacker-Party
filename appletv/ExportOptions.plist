<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- xcodebuild -exportArchive options for the App Store .ipa (used by
     .github/workflows/release.yml and for local exports). Mirrors the manual
     signing setup in project.yml: Apple Distribution cert + the named App Store
     provisioning profile. destination=export writes the .ipa to disk; release
     tag builds flip it to "upload" at runtime (plutil, in release.yml) to push
     the build to App Store Connect via the ASC API key.
     manageAppVersionAndBuildNumber=false keeps xcodebuild from second-guessing
     the version: release builds stamp MARKETING_VERSION (from the git tag) and
     CURRENT_PROJECT_VERSION (run number) explicitly at archive time. -->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>export</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>teamID</key>
	<string>5ZH48MPAM3</string>
	<key>signingCertificate</key>
	<string>Apple Distribution</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.hexstacker.tv</key>
		<string>HexStacker tvOS App Store</string>
	</dict>
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
</dict>
</plist>
