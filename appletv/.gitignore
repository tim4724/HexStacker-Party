# Xcode (the .xcodeproj is generated from project.yml via XcodeGen)
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.xcuserstate

# Build output
build/
.build/
# xcodebuild derivedDataPath (app-target builds / CI)
.build-xcode/
.swiftpm/

# Engine JS mirrored into the app bundle at build time (single source of
# truth lives in ../server and ../public/shared; never edit the copies).
Sources/HexStackerTV/Generated/

# Info.plist is generated by XcodeGen from project.yml (the source of truth).
Sources/HexStackerTV/Info.plist

# Visual-parity test: local deps + generated screenshot captures
scripts/parity/node_modules/
scripts/parity/*.png

# XCUITest result bundles + extracted screenshots (regenerable; CI publishes
# them as an artifact — see .github/workflows/tvos-uitest.yml)
*.xcresult/
shots/
