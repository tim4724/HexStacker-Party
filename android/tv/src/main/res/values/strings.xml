<resources>
    <!--
      Default (English) UI strings for the :tv app. Values mirror
      `public/shared/i18n.js` `en` (the source of truth) EXACTLY — no TV-invented
      copy. Strings stored in their RAW i18n form: CSS-style uppercasing is applied
      at the render site (ChromeButton, #qr-label, .card-level__heading) as the code
      already does, NOT baked into the data.
    -->
    <string name="app_name" translatable="false">HexStacker Party</string>

    <!-- Brand wordmark (not in i18n.js; identical across all locales). -->
    <string name="wordmark_main" translatable="false">HEX STACKER</string>
    <string name="wordmark_sub" translatable="false">PARTY</string>

    <!-- Canvas HUD labels (already-uppercase in the i18n data; drawn verbatim). -->
    <string name="hold">HOLD</string>
    <string name="next">NEXT</string>
    <string name="level">LEVEL</string>
    <string name="lines">LINES</string>
    <string name="ko">KO</string>
    <string name="go">GO</string>
    <string name="scan_to_rejoin">SCAN</string>

    <!-- Line-clear popups (i18n double / triple; drawn verbatim like the web). -->
    <string name="double_clear">DOUBLE</string>
    <string name="triple_clear">TRIPLE!</string>

    <!-- Lobby. -->
    <string name="scan_hint">Scan code with your phone</string>
    <string name="waiting_for_players">Waiting for players</string>
    <string name="level_heading">Level</string>

    <!-- Results. -->
    <string name="level_n">Level %1$d</string>
    <string name="new_player">New player</string>
    <string name="play_again">Play Again</string>
    <string name="new_game">New Game</string>
    <!-- DisplayUI '–' (en-dash) rank for late joiners (not localized). -->
    <string name="late_joiner_rank" translatable="false">–</string>

    <!-- Pause. -->
    <string name="paused">PAUSED</string>
    <string name="continue_btn">Continue</string>
    <string name="settings_game_music">Game Music</string>

    <!-- Connection overlay. -->
    <string name="reconnecting">RECONNECTING</string>
    <string name="disconnected">DISCONNECTED</string>
    <string name="attempt_n_of_m">Attempt %1$d of %2$d</string>
    <string name="reconnect">RECONNECT</string>

    <!-- Unnamed-player fallback (i18n player). -->
    <string name="player">Player</string>

    <!-- About screen: QR-card labels for the web privacy / imprint pages
         (mirrors i18n.js privacy / imprint; localized per-locale). -->
    <string name="privacy">Privacy</string>
    <string name="imprint">Imprint</string>

    <!-- Licenses screen (reached from the lobby footer). TV-only (the web app
         ships no licenses page) but localized like the rest of this file: added to
         i18n.js as the cross-platform source and mirrored per-locale. "Licenses",
         not "Open Source Licenses": the list includes the CC BY lobby music, and CC
         licenses are not open source licenses. No on-screen back hint — the
         remote's Back button navigates back implicitly.
         Doubles as the lobby entry-link label and the screen title. -->
    <string name="licenses_title">Licenses</string>

    <!-- Plurals (i18n start_n_players / n_lines). -->
    <plurals name="start_n_players">
        <item quantity="one">START (%1$d player)</item>
        <item quantity="other">START (%1$d players)</item>
    </plurals>
    <plurals name="n_lines">
        <item quantity="one">%1$d line</item>
        <item quantity="other">%1$d lines</item>
    </plurals>
</resources>
