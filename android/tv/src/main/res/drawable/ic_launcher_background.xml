<?xml version="1.0" encoding="utf-8"?>
<!-- HexStacker launcher icon background: brand-plum with a soft off-centre
     glow (lighter card-plum core fading to the deep board plum at the edges)
     so the masked icon reads as an intentional surface, not a flat plate.
     Light comes from the upper-left to match the foreground gem's sheen. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="44" android:centerY="42"
                android:gradientRadius="92">
                <item android:offset="0.0" android:color="#2A2540" />
                <item android:offset="0.62" android:color="#1E1A2B" />
                <item android:offset="1.0" android:color="#15121F" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
