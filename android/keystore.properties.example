# Release signing config for the :tv Android app. Copy to `keystore.properties`
# (same directory — the android/ Gradle root) and fill in your upload keystore
# details. The real file is gitignored; NEVER commit it or the keystore.
#
# Create the upload keystore once (keep the .jks and these passwords backed up —
# losing them means you can no longer update the app on Play):
#
#   keytool -genkeypair -v \
#     -keystore android/upload-keystore.jks \
#     -alias hexstacker-upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ Gradle root.
storeFile=upload-keystore.jks
storePassword=CHANGEME
keyAlias=hexstacker-upload
keyPassword=CHANGEME
